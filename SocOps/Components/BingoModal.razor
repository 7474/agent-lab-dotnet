<div class="fixed inset-0 retro-modal-overlay flex items-center justify-center p-4 z-50">
    <div class="retro-modal rounded-xl p-6 max-w-xs w-full text-center animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="text-3xl font-bold mb-2 retro-title">BINGO!</h2>
        <p class="mb-6 retro-subtitle">1列そろいました！お見事です。</p>

        <button
            @onclick="OnDismiss"
            class="retro-btn py-3 px-6 rounded-lg">
            つづける
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
