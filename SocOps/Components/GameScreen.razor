@using SocOps.Models

<div class="flex flex-col min-h-full retro-page">
    <header class="retro-panel rounded mx-auto w-full max-w-md" style="margin-top:0.75rem;">
        <div class="retro-header-grid">
            <div class="retro-header-cell">
                <button
                    @onclick="OnReset"
                    class="retro-link-btn text-sm">
                    ← もどる
                </button>
            </div>
            <div class="retro-header-cell center">
                <h1 class="font-bold retro-title">Soc Ops</h1>
            </div>
            <div class="retro-header-cell right text-xs retro-subtitle">PLAYING...</div>
        </div>
    </header>

    <p class="retro-instruction text-center text-sm max-w-md mx-auto">
        お題に当てはまる人を見つけたら、そのマスをタップしてください。
    </p>

    @if (HasBingo)
    {
        <div class="retro-bingo-banner text-sm max-w-md mx-auto">
            ★ BINGO! 1列そろいました ★
        </div>
    }

    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
